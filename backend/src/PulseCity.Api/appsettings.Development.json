{
  "PulseCity": {
    "Database": {
      "Provider": "sqlserver",
      "ApplyMigrationsOnStartup": false
    },
    "Jwt": {
      "SigningKey": "PulseCity-Development-Signing-Key-Replace-This-Immediately",
      "AccessTokenMinutes": 20160
    },
    "Storage": {
      "UploadRootPath": "%LOCALAPPDATA%\\PulseCity\\storage\\public",
      "ExportRootPath": "%LOCALAPPDATA%\\PulseCity\\storage\\private\\exports",
      "OutboundMailRootPath": "%LOCALAPPDATA%\\PulseCity\\storage\\private\\mail",
      "LegacyUploadRootPath": "Uploads",
      "PublicBasePath": "/uploads",
      "MaxUploadSizeMb": 30
    },
    "Smtp": {
      "Host": "smtp.placeholder.local",
      "Port": 587,
      "UseSsl": true,
      "UserName": "smtp-user-placeholder",
      "Password": "TEMP_SMTP_PASSWORD_CHANGE_ME",
      "SenderEmail": "noreply@pulsecity.local",
      "SenderName": "PulseCity",
      "PasswordResetBaseUrl": "pulsecity://reset-password",
      "PasswordResetCodeLength": 10,
      "PasswordResetExpiresMinutes": 30
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
