{
  "ConnectionStrings": {
    "SqlServer": "Server=localhost;Database=PulseCityLocal;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "PulseCity": {
    "Database": {
      "ApplyMigrationsOnStartup": false
    },
    "Redis": {
      "ConnectionString": "",
      "InstanceName": "pulsecity:"
    },
    "GooglePlaces": {
      "ApiKey": "",
      "NearbyCacheMinutes": 5,
      "DetailCacheMinutes": 30
    },
    "Jwt": {
      "Issuer": "PulseCity.Api",
      "Audience": "PulseCity.Mobile",
      "SigningKey": "",
      "AccessTokenMinutes": 20160
    },
    "Storage": {
      "UploadRootPath": "%LOCALAPPDATA%\\PulseCity\\storage\\public",
      "ExportRootPath": "%LOCALAPPDATA%\\PulseCity\\storage\\private\\exports",
      "OutboundMailRootPath": "%LOCALAPPDATA%\\PulseCity\\storage\\private\\mail",
      "LegacyUploadRootPath": "Uploads",
      "PublicBasePath": "/uploads",
      "MaxUploadSizeMb": 30
    },
    "Smtp": {
      "Host": "smtp.example.com",
      "Port": 587,
      "UseSsl": true,
      "UserName": "smtp-user@example.com",
      "Password": "TEMP_SMTP_PASSWORD",
      "SenderEmail": "noreply@pulsecity.app",
      "SenderName": "PulseCity",
      "PasswordResetBaseUrl": "pulsecity://reset-password",
      "PasswordResetCodeLength": 8,
      "PasswordResetExpiresMinutes": 30
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:5275",
        "http://10.0.2.2:5275"
      ]
    },
    "Fcm": {
      "ProjectId": "anonymap-2907",
      "ServiceAccountJson": "",
      "ServiceAccountJsonFile": ""
    },
    "KeyVault": {
      "Uri": "",
      "ReloadIntervalMinutes": 10
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
